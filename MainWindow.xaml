<Window
    x:Class="RogerPDF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" IsTabStop="True" TabIndex="0"
          KeyDown="OnKeyDown" Loaded="OnGridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="Assets/WindowIcon.png" Width="16" Height="16"/>
                <TextBlock x:Name="TitleTextBlock" Text="Roger PDF"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <CommandBar Grid.Row="1" Background="Transparent"
                    DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="OpenFile" Label="Open PDF" Click="OpenButton_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Previous" x:Name="BtnPrev" Click="Prev_Click"/>
            <AppBarElementContainer VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="PageInputBox"
                             Width="45" Height="32"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             FontSize="13"
                             KeyDown="OnPageInputKeyDown"
                             LostFocus="OnPageInputLostFocus"
                             Text="1"
                             Margin="4,0"/>
                    <TextBlock x:Name="PageTotalText"
                               Text="/ 0"
                               VerticalAlignment="Center"
                               Margin="4,0"/>
                </StackPanel>
            </AppBarElementContainer>
            <AppBarButton Icon="Next" x:Name="BtnNext" Click="Next_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="ZoomOut" Click="ZoomOut_Click"/>
            <AppBarElementContainer VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <Slider x:Name="ZoomSlider" Width="120" Minimum="40" Maximum="400"
                            Value="150" ValueChanged="ZoomSlider_ValueChanged"/>
                    <TextBox x:Name="ZoomInputBox"
                             Width="55" Height="32"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             FontSize="13"
                             KeyDown="OnZoomInputKeyDown"
                             LostFocus="OnZoomInputLostFocus"
                             Text="150"/>
                    <TextBlock Text="%" VerticalAlignment="Center"/>
                </StackPanel>
            </AppBarElementContainer>
            <AppBarButton Icon="ZoomIn" Click="ZoomIn_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="BackToWindow" Label="Fit Page" Click="FitPage_Click"/>
            <AppBarButton Icon="AlignCenter" Label="Fit Width" Click="FitWidth_Click"/>
            <AppBarToggleButton x:Name="BtnContinuous" Icon="List" Label="Continuous" Click="Continuous_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Help" Label="About" Click="OnAboutClick"/>
        </CommandBar>

        <!--
            ZoomMode="Enabled" to allow touchpad pinch gestures.
            We intercept ViewChanged to extract the zoom factor, fold it into
            currentZoom, reset ScrollViewer zoom back to 1.0, and re-render.
        -->
        <ScrollViewer x:Name="PdfScrollViewer" Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      ZoomMode="Enabled"
                      MinZoomFactor="1.0"
                      MaxZoomFactor="1.0"
                      ViewChanged="OnScrollViewerViewChanged"
                      SizeChanged="OnScrollViewerSizeChanged">
            <Grid x:Name="PdfContentGrid" Background="Transparent" Padding="40"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="PdfDisplayImage" Stretch="None"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image.Shadow>
                        <ThemeShadow/>
                    </Image.Shadow>
                </Image>
                <StackPanel x:Name="ContinuousPanel" Orientation="Vertical"
                            HorizontalAlignment="Center" Spacing="16"
                            Visibility="Collapsed"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
